{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "build"
    },
    {
      "label": "Run Backend",
      "type": "shell",
      "command": "uvicorn main:app --reload",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "build"
    },
    {
      "label": "Run Both",
      "dependsOn": ["Run Frontend", "Run Backend"],
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
